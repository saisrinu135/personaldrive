# Database Configuration
DATABASE_URL=postgresql://cloudstorage_user:cloudstorage_pass@localhost:5432/cloudstorage_db
POSTGRES_USER=cloudstorage_user
POSTGRES_PASSWORD=cloudstorage_pass
POSTGRES_DB=cloudstorage_db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRY_HOURS=24

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# App Configuration
DEBUG=true
APP_NAME=CloudVault
APP_VERSION=1.0.0

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api